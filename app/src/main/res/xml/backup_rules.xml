<?xml version="1.0" encoding="utf-8"?>
<!--
   Exclude Room database and DataStore — Firestore is the source of truth
   for logged-in users; restoring stale local data causes sync conflicts.
   Note: This file is ignored for devices running API 31+.
   See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <exclude domain="database" path="mybooks_library.db" />
    <exclude domain="database" path="mybooks_library.db-shm" />
    <exclude domain="database" path="mybooks_library.db-wal" />
    <exclude domain="file" path="datastore/user_preferences.preferences_pb" />
</full-backup-content>
