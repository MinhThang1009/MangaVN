#!/bin/sh
# Pre-commit hook: ktlintCheck + detekt khi có staged .kt files.
# Cài tự động qua Gradle task installGitHooks (chạy khi build lần đầu).

STAGED_KT=$(git diff --cached --name-only --diff-filter=ACM | grep '\.kt$')
if [ -z "$STAGED_KT" ]; then
    exit 0
fi

if [ -f "./gradlew" ]; then
    GRADLEW="./gradlew"
else
    echo "Không tìm thấy gradlew — bỏ qua kiểm tra."
    exit 0
fi

echo ">>> ktlint + detekt: kiểm tra staged .kt files..."

"$GRADLEW" ktlintCheck detekt --console=plain -q
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo ""
    echo "FAILED — sửa violations rồi commit lại."
    echo "  ktlint: Linux/macOS dùng './gradlew ktlintFormat' để auto-fix (không dùng trên Windows)."
    echo "  detekt: xem chi tiết tại app/build/reports/detekt/detekt.html"
fi
exit $STATUS
